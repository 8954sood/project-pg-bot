# Required: Discord bot runtime
# BOT_TOKEN is required to start the Discord bot.
BOT_TOKEN=

# Required: Discord LLM memory bot
# Format: guild_id:channel_id,channel_id;guild_id:channel_id
# The LLM bot ignores every guild/channel not listed here.
LLM_GUILD_CHANNEL_MAP=

# Required: Main LLM provider
# LLM_MODEL and one API key are required for LLM responses.
# Priority: LLM_* > OPENAI_* > generic aliases.
LLM_API_KEY=
LLM_MODEL=

# Optional: existing bot runtime config
# DEV_GUILD_ID is used for command sync. Defaults to 1074259285825032213.
DEV_GUILD_ID=
# OPUS_PATH is used on macOS when loading the Discord voice Opus library.
OPUS_PATH=
# LOG_LEVEL defaults to INFO.
LOG_LEVEL=INFO

# Optional: TTS runtime config
# AI_TTS_WS_URL is required only when using the AI TTS engine.
AI_TTS_WS_URL=
TTS_MAX_QUEUE_SIZE=50
TTS_MAX_TEXT_LENGTH=300
TTS_GTTS_TIMEOUT_SECONDS=10
TTS_AI_FIRST_CHUNK_TIMEOUT_SECONDS=3

# Optional: Main LLM provider details
# LLM_BASE_URL defaults to https://api.openai.com/v1.
LLM_BASE_URL=
LLM_TIMEOUT_SECONDS=180
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# Optional: OpenAI-compatible aliases
# Use these instead of LLM_* if needed. LLM_* values take priority.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENAI_TIMEOUT_SECONDS=
OPENAI_TEMPERATURE=
OPENAI_MAX_TOKENS=

# Optional: Generic LLM aliases
# Used only when matching LLM_* and OPENAI_* values are empty.
API_KEY=
BASE_URL=
MODEL=

# Optional: Consent
# Changing this value forces users to consent again.
LLM_CONSENT_VERSION=2026-06-llm-memory-v1

# Optional: Payload logging
# Payload logging is off by default. API keys are redacted.
LLM_LOG_PAYLOADS=false
LLM_LOG_PAYLOAD_MAX_CHARS=2000
OPENAI_LOG_PAYLOADS=false
OPENAI_LOG_PAYLOAD_MAX_CHARS=2000

# Optional: Discord LLM runtime
LLM_DEBOUNCE_SECONDS=2
LLM_RESPONSE_COOLDOWN_SECONDS=3
LLM_MAX_RECENT_LOGS=80
LLM_MAX_RECENT_CONVERSATION_LINES=12
LLM_MAX_GLOBAL_CONTEXT_CHARS=3000
LLM_MAX_PARTICIPANT_CONTEXT_CHARS=3000
LLM_MAX_RECENT_CONTEXT_CHARS=5000
LLM_MAX_TOOL_CONTEXT_CHARS=3000
LLM_MAX_CURRENT_BUFFER_CHARS=3000
LLM_TYPING_REFRESH_SECONDS=8
